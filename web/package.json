    "recharts": "^2.12.7",
    "tesseract.js": "^5.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "vitest": "^2.0.5",
    "typescript": "^5.5.4"
  },
  "devDependencies": {}
