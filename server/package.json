{
  "name": "@fairsplit/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "build:vercel": "npm run build --workspace @fairsplit/core && npm run build --workspace @fairsplit/server && npm run build --workspace @fairsplit/web"
  },
  "dependencies": {
    "@fairsplit/core": "file:../packages/core",
    "@prisma/client": "^5.18.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8",
    "tesseract.js": "^5.1.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "vitest": "^2.0.5",
    "@types/node": "^20.14.11",
    "typescript": "^5.5.4",
    "web-push": "^3.6.7",
    "@types/web-push": "^3.6.4"
  },
  "devDependencies": {},
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
