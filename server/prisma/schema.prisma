generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String
  passwordHash String
  defaultCurrency String @default("EUR")
  createdAt DateTime @default(now())
  memberships GroupMember[]
  paid ExpensePayer[]
  splits ExpenseSplit[]
  paymentsMade Settlement[] @relation("SettlementFrom")
  paymentsReceived Settlement[] @relation("SettlementTo")
  comments Comment[]
  pushSubscriptions PushSubscription[]
  receiptArchives ReceiptArchive[]
}

model Group {
  id String @id @default(cuid())
  name String
  type String @default("general")
  currency String @default("EUR")
  simplifyDebts Boolean @default(true)
  createdAt DateTime @default(now())
  members GroupMember[]
  expenses Expense[]
  settlements Settlement[]
  receiptArchives ReceiptArchive[]
}

model GroupMember {
  id String @id @default(cuid())
  groupId String
  userId String
  role String @default("MEMBER")
  group Group @relation(fields: [groupId], references: [id])
  user User @relation(fields: [userId], references: [id])
  @@unique([groupId, userId])
}

model Expense {
  id String @id @default(cuid())
  groupId String?
  title String
  category String @default("general")
  description String?
  total Int
  currency String @default("EUR")
  splitKind String
  date DateTime @default(now())
  status String @default("active")
  receiptUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group Group? @relation(fields: [groupId], references: [id])
  payers ExpensePayer[]
  splits ExpenseSplit[]
  comments Comment[]
  recurrence Recurrence?
  receiptArchives ReceiptArchive[]
}

model ExpensePayer {
  id String @id @default(cuid())
  expenseId String
  userId String
  amount Int
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model ExpenseSplit {
  id String @id @default(cuid())
  expenseId String
  userId String
  amount Int
  rawValue Float?
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Settlement {
  id String @id @default(cuid())
  groupId String?
  fromUserId String
  toUserId String
  amount Int
  currency String @default("EUR")
  note String?
  date DateTime @default(now())
  group Group? @relation(fields: [groupId], references: [id])
  fromUser User @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser User @relation("SettlementTo", fields: [toUserId], references: [id])
}

model Comment {
  id String @id @default(cuid())
  expenseId String
  userId String
  body String
  createdAt DateTime @default(now())
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Recurrence {
  id String @id @default(cuid())
  expenseId String @unique
  frequency String
  interval Int @default(1)
  nextRunAt DateTime
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}


model PushSubscription {
  id String @id @default(cuid())
  userId String
  endpoint String @unique
  p256dh String
  auth String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReceiptArchive {
  id String @id @default(cuid())
  groupId String
  uploaderId String
  fileName String?
  mimeType String @default("image/jpeg")
  imageDataUrl String
  note String?
  expenseId String?
  createdAt DateTime @default(now())
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
}
